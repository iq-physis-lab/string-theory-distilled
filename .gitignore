*.fls
*.synctex.gz
*.toc
*.out
*.bbl
*.blg
*.dvi
*.lof
*.lot

# ── Secrets / Credentials ────────────────────────────────────────────────────
.env.local
.env.*.local
secrets.py
credentials.json
*.pem
*.key

